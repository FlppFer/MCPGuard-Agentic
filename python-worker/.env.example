# Go API callback
MCPGUARD_API_URL=http://localhost:8080
MCPGUARD_API_KEY=dev-key
MCPGUARD_CLIENT_ID=dev-client

# Storage — LocalStack S3 (matches Go API default config)
STORAGE_MODE=s3
S3_BUCKET=mcpguard-local-storage
S3_ENDPOINT=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1

# LLM — Google Gemini free tier (15 RPM, 1M tokens/min, no billing needed)
# 1. Go to https://aistudio.google.com/apikey
# 2. Click "Create API key" and copy it
# 3. Paste the key as LLM_API_KEY below
LLM_API_KEY=your-gemini-api-key-here
LLM_MODEL=gemini-3.0-flash
# Other free Gemini models: gemini-3.1-flash-lite (faster, cheaper), gemini-2.5-pro (smarter, stricter limits)

# Worker
WORKER_PORT=5000
LOG_LEVEL=info
